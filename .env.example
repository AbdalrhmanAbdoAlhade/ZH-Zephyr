# ──────────────────────────────────────────
#  ZH Mini-Backend — Environment Config
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ──────────────────────────────────────────

# Application
APP_NAME="ZH Mini Backend"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=root
DB_PASS=

# ──────────────────────────────────────────
# Auth / Security
# ──────────────────────────────────────────
APP_SECRET=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=3600

# ──────────────────────────────────────────
# Payment Gateways (Egyptian Market)
# ──────────────────────────────────────────
EDFAPAY_MERCHANT_ID=
EDFAPAY_SECRET_KEY=
EDFAPAY_API_URL=https://api.edfapay.com

FAWATERAK_API_KEY=
FAWATERAK_API_URL=https://staging.fawaterak.com/api/v2

# ──────────────────────────────────────────
# Shipping Providers
# ──────────────────────────────────────────
NAQEL_API_KEY=
NAQEL_API_URL=

FASTLO_API_KEY=
FASTLO_API_URL=

# ──────────────────────────────────────────
# Mail (Optional)
# ──────────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"
