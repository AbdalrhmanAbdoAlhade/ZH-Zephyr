{
    "name": "zh-innovation/mini-backend",
    "description": "A lightweight and high-performance PHP Backend Framework Engine.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdalrhman AbdoAlhade",
            "email": "abdo.king22227@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "App\\": "app/"
        },
        "files": [
            "core/helpers.php"
        ]
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
